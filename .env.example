# Qdrant Local Configuration (Docker)
# Start Qdrant with: docker compose up -d

# Your local Qdrant instance
QDRANT_URL=http://localhost:6333

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Comet Opik Configuration (for Bonus notebook)
# Create a free account at: https://www.comet.com/signup
# Get your API key from: https://www.comet.com/account-settings
OPIK_API_KEY=your-opik-api-key-here

